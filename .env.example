OPENAI_API_KEY=

# Defaults match the requested MVP. Override when your account has newer preferred models.
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Video/render knobs.
MANGA2ANIME_OUTPUT_DIR=outputs
MANGA2ANIME_FPS=24
MANGA2ANIME_MAX_PAGES=20
MANGA2ANIME_MAX_SHOTS=8
